# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real keys.
#
# Alpaca offers two completely separate environments:
#   - PAPER:  fake money, real market data. Use this for everything until a
#             strategy has passed the registry's promotion gates.
#   - LIVE:   real money. Only flip to this after explicit, deliberate review.
#
# Get keys from: https://app.alpaca.markets/  (Paper vs Live toggle in UI)

# --- Alpaca PAPER account (default for development) ---
ALPACA_PAPER_API_KEY=your_paper_key_here
ALPACA_PAPER_API_SECRET=your_paper_secret_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# --- Alpaca LIVE account (leave blank until you're truly ready) ---
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# Which environment the application should use by default.
# Valid values: paper | live
ALPACA_ENV=paper

# --- Email sender (for the autonomous agent's daily/weekly/monthly reports) ---
# Gmail SMTP is the recommended path:
#   1. Use any Gmail account you control.
#   2. Enable 2FA on it (myaccount.google.com -> Security).
#   3. Create an app password: Security -> 2FA -> App passwords.
#      Pick "Mail" / "Other" and copy the 16-character password.
#   4. Fill SMTP_USERNAME with the full Gmail address, SMTP_PASSWORD
#      with the 16-character app password (no spaces).
#
# REPORT_TO is where the agent sends reports. REPORT_FROM is what
# appears in the From: header (usually same as SMTP_USERNAME).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
REPORT_FROM=
REPORT_TO=terrancehan@outlook.com

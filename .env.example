# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real keys.
#
# Alpaca offers two completely separate environments:
#   - PAPER:  fake money, real market data. Use this for everything until a
#             strategy has passed the registry's promotion gates.
#   - LIVE:   real money. Only flip to this after explicit, deliberate review.
#
# Get keys from: https://app.alpaca.markets/  (Paper vs Live toggle in UI)

# --- Alpaca PAPER account (default for development) ---
ALPACA_PAPER_API_KEY=your_paper_key_here
ALPACA_PAPER_API_SECRET=your_paper_secret_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# --- Alpaca LIVE account (leave blank until you're truly ready) ---
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# Which environment the application should use by default.
# Valid values: paper | live
ALPACA_ENV=paper
